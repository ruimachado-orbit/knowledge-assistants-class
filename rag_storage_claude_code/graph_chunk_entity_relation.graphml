    <node id="Maria Santos">
      <data key="d0">Maria Santos</data>
      <data key="d1">person</data>
      <data key="d2">Maria Santos is the CEO of TechNova, to whom Lucas Pereira reports directly.&lt;SEP&gt;Maria Santos is the CEO of TechNova, having joined in 2018 as VP Engineering and becoming CEO in 2021. She co-signed the GlobalBank contract.</data>
      <data key="d3">chunk-26b70bcb25c48c30ce81c6a5c453d7ec&lt;SEP&gt;chunk-9049a6def58666ef149896d797cc954e</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776799417</data>
      <data key="d6" />
    </node>
    <node id="Jorge Ferreira">
      <data key="d0">Jorge Ferreira</data>
      <data key="d1">person</data>
      <data key="d2">Jorge Ferreira is a TechNova employee working on the Spanish market expansion alongside Lucas Pereira.&lt;SEP&gt;Jorge Ferreira is the CTO of TechNova since 2019, previously worked at Farfetch and Unbabel, and coordinated the CNPD audit response and leads the Spanish market expansion.</data>
      <data key="d3">chunk-26b70bcb25c48c30ce81c6a5c453d7ec&lt;SEP&gt;chunk-9049a6def58666ef149896d797cc954e</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776799417</data>
      <data key="d6" />
    </node>
    <node id="RetailCo">
      <data key="d0">RetailCo</data>
      <data key="d1">organization</data>
      <data key="d2">RetailCo is a client of TechNova that expanded their Orion contract to include the new ML pipeline module.&lt;SEP&gt;RetailCo is a TechNova client onboarded in June 2023 exclusively on Orion v1.5, reporting a 40% reduction in data processing time after migration.</data>
      <data key="d3">chunk-26b70bcb25c48c30ce81c6a5c453d7ec&lt;SEP&gt;chunk-9049a6def58666ef149896d797cc954e</data>
