    <node id="Carla Mendes">
      <data key="d0">Carla Mendes</data>
      <data key="d1">person</data>
      <data key="d2">Carla Mendes is a TechNova representative who negotiated the Orion contract expansion with RetailCo.&lt;SEP&gt;Carla Mendes is TechNova's Product VP, hired from Revolut in early 2023 to lead the Orion Platform launch and co-led RetailCo's onboarding.</data>
      <data key="d3">chunk-26b70bcb25c48c30ce81c6a5c453d7ec&lt;SEP&gt;chunk-9049a6def58666ef149896d797cc954e</data>
