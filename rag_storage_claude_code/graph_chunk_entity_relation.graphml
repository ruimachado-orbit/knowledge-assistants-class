    </node>
    <node id="SAP Portugal">
      <data key="d0">SAP Portugal</data>
      <data key="d1">organization</data>
      <data key="d2">SAP Portugal is a technology company where Lucas Pereira previously led enterprise sales for 8 years before joining TechNova.</data>
      <data key="d3">chunk-26b70bcb25c48c30ce81c6a5c453d7ec</data>
      <data key="d4">unknown_source</data>
