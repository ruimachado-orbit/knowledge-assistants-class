    <node id="Apollo System">
      <data key="d0">Apollo System</data>
      <data key="d1">artifact</data>
      <data key="d2">The Apollo System is TechNova's legacy platform in production since 2019, managed by Pedro Nunes, flagged for deprecation, and maintained due to contractual obligations with GlobalBank.</data>
      <data key="d3">chunk-9049a6def58666ef149896d797cc954e</data>
      <data key="d4">unknown_source</data>
