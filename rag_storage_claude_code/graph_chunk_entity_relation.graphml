    <node id="Sofia Costa">
      <data key="d0">Sofia Costa</data>
      <data key="d1">person</data>
      <data key="d2">Sofia Costa is the IT Director at RetailCo who participated in negotiating the Orion contract expansion with TechNova.&lt;SEP&gt;Sofia Costa is RetailCo's IT Director who co-led the RetailCo onboarding onto the Orion platform.</data>
      <data key="d3">chunk-26b70bcb25c48c30ce81c6a5c453d7ec&lt;SEP&gt;chunk-9049a6def58666ef149896d797cc954e</data>
