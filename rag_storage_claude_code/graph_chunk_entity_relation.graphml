    <node id="GlobalBank">
      <data key="d0">GlobalBank</data>
      <data key="d1">organization</data>
      <data key="d2">GlobalBank is TechNova's largest client since 2021, representing 28% of total revenue, using both Apollo and Orion platforms under a contract running until December 2025.</data>
      <data key="d3">chunk-9049a6def58666ef149896d797cc954e</data>
