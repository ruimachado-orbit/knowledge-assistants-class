  <graph edgedefault="undirected">
    <node id="TechNova">
      <data key="d0">TechNova</data>
      <data key="d1">organization</data>
      <data key="d2">TechNova is a technology company that issued a press release in February 2024 announcing executive appointments and contract expansions.&lt;SEP&gt;TechNova is a technology company led by CEO Maria Santos and CTO Jorge Ferreira, which closed 2023 with €42M in revenue and is developing the Orion and Apollo platforms.</data>
      <data key="d3">chunk-26b70bcb25c48c30ce81c6a5c453d7ec&lt;SEP&gt;chunk-9049a6def58666ef149896d797cc954e</data>
      <data key="d4">unknown_source</data>
