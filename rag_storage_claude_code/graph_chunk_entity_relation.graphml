    <node id="Orion">
      <data key="d0">Orion</data>
      <data key="d1">artifact</data>
      <data key="d2">Orion is a software product by TechNova, with version 3.0 including a new ML pipeline module, scheduled for May 2024.</data>
      <data key="d3">chunk-26b70bcb25c48c30ce81c6a5c453d7ec</data>
      <data key="d4">unknown_source</data>
