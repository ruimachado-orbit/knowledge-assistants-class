      <data key="d6" />
    </node>
    <node id="Lucas Pereira">
      <data key="d0">Lucas Pereira</data>
      <data key="d1">person</data>
      <data key="d2">Lucas Pereira is the newly appointed VP of Sales for the Iberian market at TechNova, previously employed at SAP Portugal where he led enterprise sales for 8 years.</data>
      <data key="d3">chunk-26b70bcb25c48c30ce81c6a5c453d7ec</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776799381</data>
