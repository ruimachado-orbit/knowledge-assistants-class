    <node id="Iberian Market">
      <data key="d0">Iberian Market</data>
      <data key="d1">location</data>
      <data key="d2">The Iberian market refers to the geographic and commercial region comprising Portugal and Spain, for which Lucas Pereira was appointed VP of Sales at TechNova.</data>
      <data key="d3">chunk-26b70bcb25c48c30ce81c6a5c453d7ec</data>
