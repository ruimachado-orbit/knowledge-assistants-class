# Copy to .env and fill in values (never commit .env):
#   cp .env.example .env
#
# Optional: path to env file (used by notebook if set before load_dotenv)
# LIGHTRAG_ENV_FILE=.env

# -----------------------------------------------------------------------------
# Provider (required): openai | claudecli | ollama
# -----------------------------------------------------------------------------
LIGHTRAG_PROVIDER=openai

# Storage directory for graph + vectors (override per machine if needed)
LIGHTRAG_WORKING_DIR=

# -----------------------------------------------------------------------------
# Embeddings (any LIGHTRAG_PROVIDER except full-Ollama stack)
# openai = OpenAI text-embedding-* (needs OPENAI_API_KEY)
# voyage = Voyage (needs VOYAGE_API_KEY + pip install voyageai)
# ollama = local embeddings only via Ollama (needs Ollama running + pulled embed model).
#          Use with LIGHTRAG_PROVIDER=claudecli when you have Claude CLI for LLM but no cloud embed API.
# -----------------------------------------------------------------------------
EMBEDDING_BACKEND=openai

# -----------------------------------------------------------------------------
# OpenAI (required for LIGHTRAG_PROVIDER=openai; for claudecli if EMBEDDING_BACKEND=openai)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIM=1536
OPENAI_EMBEDDING_MAX_TOKENS=8192

# -----------------------------------------------------------------------------
# Claude Code CLI (only when LIGHTRAG_PROVIDER=claudecli)
# -----------------------------------------------------------------------------
CLAUDE_CODE_BIN=claude
# Leave empty to use process cwd (usually the notebook folder)
CLAUDE_CODE_CWD=
CLAUDE_CODE_TIMEOUT_SEC=600
# 1/true/yes to pass --bare (often requires ANTHROPIC_API_KEY per Anthropic docs)
CLAUDE_CODE_BARE=
# Extra CLI args, shell-style, e.g.: --permission-mode dontAsk
CLAUDE_CODE_EXTRA_ARGS=

# -----------------------------------------------------------------------------
# Ollama (LLM when LIGHTRAG_PROVIDER=ollama; OR local embeddings when EMBEDDING_BACKEND=ollama)
# -----------------------------------------------------------------------------
OLLAMA_HOST=http://localhost:11434
OLLAMA_LLM_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_EMBEDDING_DIM=768
OLLAMA_EMBEDDING_MAX_TOKENS=8192
OLLAMA_NUM_CTX=32768

# -----------------------------------------------------------------------------
# Voyage (only when EMBEDDING_BACKEND=voyage)
# -----------------------------------------------------------------------------
VOYAGE_API_KEY=
VOYAGE_EMBEDDING_MODEL=voyage-3
VOYAGE_EMBEDDING_DIM=1024
VOYAGE_EMBEDDING_MAX_TOKENS=8192
